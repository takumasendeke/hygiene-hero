void playAnime(uint8_t width, uint8_t height, uint16_t fDelay) {
  while (true) {
    for (uint8_t i = 0; i < FRAMES; i++) {
      delay(fDelay); // wait on current frame
      
      auxScreen.clearBuffer(); // clear memory to prevent overlap 

      // drawXBMP reads from PROGMEM
      auxScreen.drawXBMP(0, 0, width, height, icon[i]);
      auxScreen.sendBuffer();
    }
  }
}

void setup() {
  auxScreen.begin();
  Serial.begin(9600);
}

void loop() {
  // ST7920 is 128x64, so:
  playAnime(128, 64, 150);
}
